{
  "manifest_version": 3,
  "name": "Inbox Hidden",
  "version": "1.0.0",
  "description": "Hide the Gmail inbox by default. Reveal only when you've decided to process it. No signature injection.",
  "host_permissions": ["https://mail.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "homepage_url": "https://github.com/jasonhausenloy/inbox-hidden"
}
